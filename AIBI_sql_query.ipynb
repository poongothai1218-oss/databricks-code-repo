    "%sql\n",
    "SELECT\n",
    "  *\n",
    "FROM\n",
    "  `logistics2`.`default`.`drugs_dataset` AS drugs_dataset\n",
    "    JOIN `logistics2`.`default`.`patientsdata` AS patientsdata\n",
    "      ON drugs_dataset.`uniqueID` = patientsdata.`drugid`\n",
    "WHERE\n",
    "  drugs_dataset.`usefulCount` > 10;"
